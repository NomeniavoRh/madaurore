rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // ========== USERS - RÈGLE SPÉCIALE (pas de getUserData ici !) ==========
    match /users/{userId} {
      // Lecture : TOUJOURS autorisée pour son propre doc (évite la boucle)
      allow read: if isAuthenticated() && request.auth.uid == userId;
      
      // Liste : tous les authentifiés (pour que les dashboards fonctionnent)
      allow list: if isAuthenticated();
      
      // Création : par soi-même lors de l'inscription
      allow create: if isAuthenticated() && request.auth.uid == userId;
      
      // Mise à jour : par soi-même ou si le doc existe déjà et qu'on est admin
      allow update: if isAuthenticated() && request.auth.uid == userId;
      
      // Suppression : toujours refusée (sauf manuellement via console)
      allow delete: if false;
    }
    
    // Pour les autres collections, on peut maintenant utiliser getUserData
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }
    
    function isAdmin() {
      return hasRole('admin');
    }
    
    function isCoordinator() {
      return hasRole('regional_coordinator');
    }
    
    function isStudent() {
      return hasRole('student');
    }
    
    function userRegion() {
      let userData = getUserData();
      return userData != null ? userData.region : null;
    }
    
    // ========== REQUESTS ==========
    match /requests/{requestId} {
      allow read: if isAuthenticated();
      allow list: if isAuthenticated();
      allow create: if isStudent();
      allow update: if isAdmin() || isCoordinator();
      allow delete: if isAdmin();
    }
    
    // ========== SPONSORSHIP_REQUESTS ==========
    match /sponsorship_requests/{requestId} {
      allow read: if isAuthenticated();
      allow list: if isAuthenticated();
      allow create: if isStudent();
      allow update: if isAdmin() || isCoordinator();
      allow delete: if isAdmin();
    }
    
    // ========== VALIDATION_REQUESTS ==========
    match /validation_requests/{validationId} {
      allow read: if isAuthenticated();
      allow list: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdmin() || isCoordinator();
      allow delete: if isAdmin();
    }
    
    // ========== UPDATES ==========
    match /updates/{updateId} {
      allow read, list: if isAuthenticated();
      allow create: if isStudent();
      allow update, delete: if isAdmin();
    }
    
    // ========== JUSTIFICATIFS ==========
    match /justificatifs/{justificatifId} {
      allow read, list: if isAuthenticated();
      allow create: if isStudent();
      allow update, delete: if isAdmin();
    }
    
    // ========== REGIONS ==========
    match /regions/{regionId} {
      allow read, list: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}