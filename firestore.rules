rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Fonction utilitaire pour vérifier le rôle via custom claims
    function isRole(role) {
      return request.auth.token.role == role;
    }

    // Fonction utilitaire pour vérifier si l'utilisateur est authentifié
    function isAuthenticated() {
      return request.auth != null;
    }

    // Fonction utilitaire pour vérifier si le document appartient à la même région (via custom claims)
    function isSameRegion() {
      return resource.data.region == request.auth.token.region;
    }

    // Fonction utilitaire pour vérifier si l'étudiant est validé
    function isValidatedStudent() {
      return isRole('student') && resource.data.status == 'approved';
    }

    // --- USERS ---
    match /users/{userId} {
      // Étudiant → peut lire/écrire uniquement son propre profil si validé
      allow read: if isAuthenticated() && isRole('student') && request.auth.uid == userId && isValidatedStudent();
      allow create, update: if isAuthenticated() && isRole('student') && request.auth.uid == userId;

      // Coordinateur → peut lire et mettre à jour les utilisateurs de sa région
      allow read, update: if isAuthenticated() && isRole('coordinator') && isSameRegion();

      // Admin → accès total
      allow read, create, update, delete: if isAuthenticated() && isRole('admin');
    }

    // --- SPONSORSHIP REQUESTS (demandes de parrainage) ---
    match /sponsorship_requests/{reqId} {
      // Étudiant → peut créer et lire ses propres demandes
      allow create: if isAuthenticated() && isRole('student') && request.resource.data.userId == request.auth.uid;
      allow read: if isAuthenticated() && isRole('student') && resource.data.userId == request.auth.uid;

      // Coordinateur → peut lire et mettre à jour les demandes de sa région
      allow read, update: if isAuthenticated() && isRole('coordinator') && isSameRegion();

      // Admin → accès total
      allow read, create, update, delete: if isAuthenticated() && isRole('admin');
    }

    // --- VALIDATION REQUESTS (inscriptions en attente) ---
    match /validation_requests/{valId} {
      // Étudiant → peut créer une validation pour son compte
      allow create: if isAuthenticated() && isRole('student') && request.resource.data.userId == request.auth.uid;

      // Coordinateur → peut lire et valider les demandes de sa région
      allow read, update: if isAuthenticated() && isRole('coordinator') && isSameRegion();

      // Admin → accès total
      allow read, create, update, delete: if isAuthenticated() && isRole('admin');
    }

    // --- UPDATES (actualités mensuelles, infos générales) ---
    match /updates/{docId} {
      // Lecture accessible à tous les utilisateurs connectés
      allow read: if isAuthenticated();

      // Admin et coordinateur peuvent écrire
      allow create, update, delete: if isAuthenticated() && (isRole('admin') || isRole('coordinator'));
    }

    // --- REQUESTS ---
    match /requests/{docId} {
      // Étudiant → peut créer et lire ses propres demandes
      allow create: if isAuthenticated() && isRole('student') && request.resource.data.userId == request.auth.uid;
      allow read: if isAuthenticated() && isRole('student') && resource.data.userId == request.auth.uid;

      // Coordinateur → peut lire et mettre à jour les demandes de sa région
      allow read, update: if isAuthenticated() && isRole('coordinator') && isSameRegion();

      // Admin → accès total
      allow read, create, update, delete: if isAuthenticated() && isRole('admin');
    }

    // --- JUSTIFICATIFS ---
    match /justificatifs/{docId} {
      // Étudiant → peut créer et lire ses propres justificatifs
      allow create: if isAuthenticated() && isRole('student') && request.resource.data.userId == request.auth.uid;
      allow read: if isAuthenticated() && isRole('student') && resource.data.userId == request.auth.uid;

      // Coordinateur → peut lire les justificatifs de sa région
      allow read: if isAuthenticated() && isRole('coordinator') && isSameRegion();

      // Admin → accès total
      allow read, create, update, delete: if isAuthenticated() && isRole('admin');
    }

    // --- REGIONS (si utilisée pour les listes dynamiques) ---
    match /regions/{docId} {
      // Lecture publique pour tous les utilisateurs connectés
      allow read: if isAuthenticated();

      // Écriture réservée aux admins
      allow create, update, delete: if isAuthenticated() && isRole('admin');
    }

    // Règle générale : interdire l’accès non spécifié
    match /{document=**} {
      allow read, write: if false;
    }
  }
}